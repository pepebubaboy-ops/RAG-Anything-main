# Local-first genealogy RAG configuration.
#
# Copy this file to .env for local development.
# Defaults point to local or on-prem services only.

GENEALOGY_RAG_OFFLINE=1
RAGANYTHING_OFFLINE=1

# Local OpenAI-compatible LLM endpoint, for example Ollama, vLLM, or llama.cpp.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT=300
LLM_MAX_TOKENS=900

# Backward-compatible local names used by older scripts.
LLM_BINDING_HOST=http://localhost:11434/v1
LLM_BINDING_API_KEY=ollama

# Optional local embedding endpoint for future retrieval work.
EMBEDDING_BASE_URL=http://localhost:8080
EMBEDDING_MODEL=bge-m3

# Optional local graph database.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me

# Local paths.
INPUT_DIR=./inputs
OUTPUT_DIR=./outputs

# Logging.
LOG_LEVEL=INFO
