# genealogy-rag-core local-first defaults
#
# Copy to .env only for local development. The defaults below point to local
# or on-prem services. Do not put private books, OCR text, prompts, embeddings,
# model outputs, or logs into external APIs unless you explicitly opt in.

# Strict local/offline mode. PDF parsing can require local models/tools that
# should already be installed on the machine.
GENEALOGY_RAG_OFFLINE=1
RAGANYTHING_OFFLINE=1

# Local OpenAI-compatible LLM endpoint, for example Ollama.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT=300
LLM_MAX_TOKENS=900

# Backward-compatible names read by older local scripts.
LLM_BINDING_HOST=http://localhost:11434/v1
LLM_BINDING_API_KEY=ollama

# Local embedding endpoint placeholders for downstream/on-prem integrations.
EMBEDDING_BASE_URL=http://localhost:8080
EMBEDDING_MODEL=bge-m3

# Optional local Neo4j instance. Leave unused unless you install the neo4j extra.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=

# Optional local parser configuration.
MINERU_BACKEND=pipeline
MINERU_MODEL_SOURCE=local
MINERU_LANG=
MINERU_PARSE_METHOD=auto
